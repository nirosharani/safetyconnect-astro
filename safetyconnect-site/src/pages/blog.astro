    <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:24px;">
      <a href="#" style="background:var(--surface-2);border:1px solid var(--steel-200);border-radius:8px;padding:24px;text-decoration:none;color:inherit;">
        <div style="font-size:11px;color:var(--steel-600);letter-spacing:0.08em;">PRACTICE</div>
