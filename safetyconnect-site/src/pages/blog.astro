<section class="section surface-white" id="process" style="padding-top:64px;padding-bottom:56px;">
  <div class="container">
    <div style="display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:32px;">
      <div>
        <span class="eyebrow">Process Safety</span>
