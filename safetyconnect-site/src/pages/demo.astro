---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteNav from '../components/SiteNav.astro';
import SiteFooter from '../components/SiteFooter.astro';
import '../styles/global.css';
---

<BaseLayout
  title="Get a demo — see SafetyConnect on your scenarios | SafetyConnect"
  description="Book a 30-minute walkthrough on your real permit types, incident workflows, and sites."
>
  <SiteNav />

<!-- Hero with form -->
<section class="hero surface-white">
  <div class="container">
    <div style="display:grid;grid-template-columns:1.05fr 1fr;gap:64px;align-items:start;">
      <div>
        <span class="eyebrow">Book a walkthrough</span>
        <h1 class="display-l" style="margin-bottom:24px;">A 30-minute walkthrough on your scenario.</h1>
        <p class="lead" style="margin-bottom:32px;">Not a sales pitch. Not an SDR. A senior product specialist walks through SafetyConnect's Driving Safety or Process Safety Suite, using your driver count, your sites, your industry, and your top three safety questions.</p>
        <div style="border-top:1px solid var(--steel-200);padding-top:32px;">
          <h3 class="h3 mb-3">What you'll get from the call:</h3>
          <ul style="list-style:none;display:flex;flex-direction:column;gap:14px;">
            <li style="display:flex;gap:14px;align-items:flex-start;">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#19A7CE" stroke-width="2" style="flex-shrink:0;margin-top:2px;"><path d="M5 12l5 5L20 7"/></svg>
              <span style="font-size:15px;color:var(--steel-700);">A live walkthrough of the product on a scenario like yours.</span>
            </li>
            <li style="display:flex;gap:14px;align-items:flex-start;">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#19A7CE" stroke-width="2" style="flex-shrink:0;margin-top:2px;"><path d="M5 12l5 5L20 7"/></svg>
              <span style="font-size:15px;color:var(--steel-700);">A rough ROI estimate based on your numbers.</span>
            </li>
            <li style="display:flex;gap:14px;align-items:flex-start;">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#19A7CE" stroke-width="2" style="flex-shrink:0;margin-top:2px;"><path d="M5 12l5 5L20 7"/></svg>
              <span style="font-size:15px;color:var(--steel-700);">Direct answers to your top three questions on privacy, security, and deployment.</span>
            </li>
            <li style="display:flex;gap:14px;align-items:flex-start;">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#19A7CE" stroke-width="2" style="flex-shrink:0;margin-top:2px;"><path d="M5 12l5 5L20 7"/></svg>
              <span style="font-size:15px;color:var(--steel-700);">A follow-up email with the resources you'd want to share with your team.</span>
            </li>
          </ul>
        </div>
      </div>

      <!-- Booking form -->
      <div style="background:#fff;border:1px solid var(--steel-200);border-radius:12px;padding:32px;box-shadow:var(--shadow-md);">
        <div style="font-size:11px;color:var(--steel-600);letter-spacing:0.08em;margin-bottom:8px;">BOOK A WALKTHROUGH</div>
        <h3 class="h2" style="margin-bottom:8px;">Tell us a little about your team.</h3>
        <p style="font-size:13.5px;color:var(--steel-700);margin-bottom:24px;">Eight fields. You'll see open times on the next screen.</p>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;">
          <div>
            <label style="display:block;font-size:12px;color:var(--navy);font-weight:600;margin-bottom:6px;">First name</label>
            <input type="text" placeholder="Thanmai" style="width:100%;padding:10px 12px;border:1px solid var(--steel-300);border-radius:6px;font-size:16px;font-family:inherit;">
          </div>
          <div>
            <label style="display:block;font-size:12px;color:var(--navy);font-weight:600;margin-bottom:6px;">Work email</label>
            <input type="email" placeholder="name@company.com" style="width:100%;padding:10px 12px;border:1px solid var(--steel-300);border-radius:6px;font-size:16px;font-family:inherit;">
          </div>
          <div style="grid-column:span 2;">
            <label style="display:block;font-size:12px;color:var(--navy);font-weight:600;margin-bottom:6px;">Company</label>
            <input type="text" placeholder="Your company" style="width:100%;padding:10px 12px;border:1px solid var(--steel-300);border-radius:6px;font-size:16px;font-family:inherit;">
          </div>
          <div>
            <label style="display:block;font-size:12px;color:var(--navy);font-weight:600;margin-bottom:6px;">Role</label>
            <select style="width:100%;padding:10px 12px;border:1px solid var(--steel-300);border-radius:5px;font-size:14px;font-family:inherit;background:#fff;">
              <option>EHS / Safety</option><option>Operations</option><option>HR</option><option>IT</option><option>Procurement</option><option>Leadership</option><option>Other</option>
            </select>
          </div>
          <div>
            <label style="display:block;font-size:12px;color:var(--navy);font-weight:600;margin-bottom:6px;">Primary interest</label>
            <select style="width:100%;padding:10px 12px;border:1px solid var(--steel-300);border-radius:5px;font-size:14px;font-family:inherit;background:#fff;">
              <option>Both</option><option>Driving Safety</option><option>Process Safety</option><option>Exploring</option>
            </select>
          </div>
          <div>
            <label style="display:block;font-size:12px;color:var(--navy);font-weight:600;margin-bottom:6px;">Approximate employees</label>
            <select style="width:100%;padding:10px 12px;border:1px solid var(--steel-300);border-radius:5px;font-size:14px;font-family:inherit;background:#fff;">
              <option>&lt; 200</option><option>200–1,000</option><option>1,000–5,000</option><option>5,000+</option>
            </select>
          </div>
          <div>
            <label style="display:block;font-size:12px;color:var(--navy);font-weight:600;margin-bottom:6px;">Country</label>
            <select style="width:100%;padding:10px 12px;border:1px solid var(--steel-300);border-radius:5px;font-size:14px;font-family:inherit;background:#fff;">
              <option>India</option><option>US</option><option>UK</option><option>EU</option><option>Other</option>
            </select>
          </div>
          <div style="grid-column:span 2;">
            <label style="display:block;font-size:12px;color:var(--navy);font-weight:600;margin-bottom:6px;">Anything you'd like us to address? <span style="font-weight:400;color:var(--steel-500);">(optional)</span></label>
            <textarea rows="2" placeholder="Top safety questions, ongoing pilot, specific use case…" style="width:100%;padding:10px 12px;border:1px solid var(--steel-300);border-radius:6px;font-size:16px;font-family:inherit;resize:vertical;"></textarea>
          </div>
        </div>
        <button class="btn btn-primary btn-lg" style="width:100%;margin-top:20px;">Pick a time →</button>
        <p style="font-size:11px;color:var(--steel-600);text-align:center;margin-top:14px;line-height:1.4;">By submitting, you agree to our Privacy Policy. We don't share your data and we don't run drip campaigns.</p>
      </div>
    </div>
  </div>
</section>

<!-- What you'll see -->
<section class="section surface-steel">
  <div class="container">
    <div class="section-header"><span class="eyebrow">What you'll see</span><h2 class="display-m">What you'll see in 30 minutes.</h2><p>The walkthrough is tailored to the suite you're most interested in. Here's how a typical session unfolds for each.</p></div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:32px;">
      <!-- Driving Safety agenda -->
      <div style="padding:36px;background:#fff;border:1px solid var(--steel-200);border-radius:10px;">
        <div style="font-size:11px;color:var(--pink);letter-spacing:0.1em;font-weight:600;text-transform:uppercase;margin-bottom:8px;">DRIVING SAFETY WALKTHROUGH</div>
        <h3 class="h2" style="margin-bottom:24px;">A 30-minute Driving Safety session.</h3>
        <div style="display:flex;flex-direction:column;gap:16px;">
          <div style="display:grid;grid-template-columns:60px 1fr;gap:16px;padding-bottom:16px;border-bottom:1px solid var(--steel-100);">
            <div style="font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--steel-500);padding-top:2px;">00–05</div>
            <div><div style="font-size:14.5px;font-weight:600;color:var(--navy);">Your context</div><div style="font-size:13.5px;color:var(--steel-700);margin-top:2px;">Your field force, your incident baseline, your top three concerns.</div></div>
          </div>
          <div style="display:grid;grid-template-columns:60px 1fr;gap:16px;padding-bottom:16px;border-bottom:1px solid var(--steel-100);">
            <div style="font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--steel-500);padding-top:2px;">05–15</div>
            <div><div style="font-size:14.5px;font-weight:600;color:var(--navy);">Driver app + manager dashboard</div><div style="font-size:13.5px;color:var(--steel-700);margin-top:2px;">Live walkthrough on real (anonymized) data.</div></div>
          </div>
          <div style="display:grid;grid-template-columns:60px 1fr;gap:16px;padding-bottom:16px;border-bottom:1px solid var(--steel-100);">
            <div style="font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--steel-500);padding-top:2px;">15–20</div>
            <div><div style="font-size:14.5px;font-weight:600;color:var(--navy);">SafetyConnect Score &amp; coaching</div><div style="font-size:13.5px;color:var(--steel-700);margin-top:2px;">How the score works, and how coaching is operationalized.</div></div>
          </div>
          <div style="display:grid;grid-template-columns:60px 1fr;gap:16px;padding-bottom:16px;border-bottom:1px solid var(--steel-100);">
            <div style="font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--steel-500);padding-top:2px;">20–25</div>
            <div><div style="font-size:14.5px;font-weight:600;color:var(--navy);">Privacy &amp; security</div><div style="font-size:13.5px;color:var(--steel-700);margin-top:2px;">Business-hours mode, RBAC, ISO 27001, data residency.</div></div>
          </div>
          <div style="display:grid;grid-template-columns:60px 1fr;gap:16px;">
            <div style="font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--steel-500);padding-top:2px;">25–30</div>
            <div><div style="font-size:14.5px;font-weight:600;color:var(--navy);">Pricing direction &amp; next steps</div><div style="font-size:13.5px;color:var(--steel-700);margin-top:2px;">Rough ROI for your numbers; clear next steps if you'd like to go further.</div></div>
          </div>
        </div>
      </div>
      <!-- Process Safety agenda -->
      <div style="padding:36px;background:#fff;border:1px solid var(--steel-200);border-radius:10px;">
        <div style="font-size:11px;color:var(--pink);letter-spacing:0.1em;font-weight:600;text-transform:uppercase;margin-bottom:8px;">PROCESS SAFETY WALKTHROUGH</div>
        <h3 class="h2" style="margin-bottom:24px;">A 30-minute Process Safety session.</h3>
        <div style="display:flex;flex-direction:column;gap:16px;">
          <div style="display:grid;grid-template-columns:60px 1fr;gap:16px;padding-bottom:16px;border-bottom:1px solid var(--steel-100);">
            <div style="font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--steel-500);padding-top:2px;">00–05</div>
            <div><div style="font-size:14.5px;font-weight:600;color:var(--navy);">Your context</div><div style="font-size:13.5px;color:var(--steel-700);margin-top:2px;">Your plant footprint, the modules you need most, your audit cadence.</div></div>
          </div>
          <div style="display:grid;grid-template-columns:60px 1fr;gap:16px;padding-bottom:16px;border-bottom:1px solid var(--steel-100);">
            <div style="font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--steel-500);padding-top:2px;">05–15</div>
            <div><div style="font-size:14.5px;font-weight:600;color:var(--navy);">PTW &amp; Incident workflows</div><div style="font-size:13.5px;color:var(--steel-700);margin-top:2px;">A real permit, an incident, a near-miss, start to close-out.</div></div>
          </div>
          <div style="display:grid;grid-template-columns:60px 1fr;gap:16px;padding-bottom:16px;border-bottom:1px solid var(--steel-100);">
            <div style="font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--steel-500);padding-top:2px;">15–20</div>
            <div><div style="font-size:14.5px;font-weight:600;color:var(--navy);">CAPA Tracking &amp; audit-readiness</div><div style="font-size:13.5px;color:var(--steel-700);margin-top:2px;">How actions, audits, and HIRA findings tie together.</div></div>
          </div>
          <div style="display:grid;grid-template-columns:60px 1fr;gap:16px;padding-bottom:16px;border-bottom:1px solid var(--steel-100);">
            <div style="font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--steel-500);padding-top:2px;">20–25</div>
            <div><div style="font-size:14.5px;font-weight:600;color:var(--navy);">Methodology &amp; integrations</div><div style="font-size:13.5px;color:var(--steel-700);margin-top:2px;">OSHA / ISO 45001 / OSH Code alignment, SAP/Oracle hookups.</div></div>
          </div>
          <div style="display:grid;grid-template-columns:60px 1fr;gap:16px;">
            <div style="font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--steel-500);padding-top:2px;">25–30</div>
            <div><div style="font-size:14.5px;font-weight:600;color:var(--navy);">Pricing direction &amp; next steps</div><div style="font-size:13.5px;color:var(--steel-700);margin-top:2px;">Rough deployment shape, indicative pricing, and pilot pathway.</div></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Who you'll meet -->
<section class="section surface-white">
  <div class="container">
    <div style="display:grid;grid-template-columns:1fr 1.4fr;gap:64px;align-items:start;">
      <div>
        <span class="eyebrow">Who you'll meet</span>
        <h2 class="display-m">A product specialist. Not an SDR.</h2>
        <p class="text-secondary body-l mt-3">The first call is always with someone who's deployed the platform, not a sales development rep reading from a script. They've worked with safety leaders at pharma, FMCG, manufacturing, and oil &amp; gas customers. They know what works and what doesn't.</p>
        <p class="text-secondary body mt-3">If you want to talk to a customer reference before or after the call, ask, we have customers across industries who are happy to share their experience.</p>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;">
        <div style="padding:24px;background:var(--surface-2);border:1px solid var(--steel-200);border-radius:8px;">
          <div style="width:48px;height:48px;border-radius:50%;background:linear-gradient(135deg,var(--teal),var(--navy));margin-bottom:14px;"></div>
          <div style="font-size:14px;color:var(--steel-600);">Senior Product Specialist</div>
          <div style="font-size:15px;color:var(--navy);font-weight:600;margin-top:4px;">Driving Safety practice</div>
          <div style="font-size:12.5px;color:var(--steel-700);margin-top:8px;line-height:1.5;">8+ years across FMCG and pharma road-safety deployments. Speaks fluent ATB.</div>
        </div>
        <div style="padding:24px;background:var(--surface-2);border:1px solid var(--steel-200);border-radius:8px;">
          <div style="width:48px;height:48px;border-radius:50%;background:linear-gradient(135deg,var(--pink),var(--navy));margin-bottom:14px;"></div>
          <div style="font-size:14px;color:var(--steel-600);">Senior Product Specialist</div>
          <div style="font-size:15px;color:var(--navy);font-weight:600;margin-top:4px;">Process Safety practice</div>
          <div style="font-size:12.5px;color:var(--steel-700);margin-top:8px;line-height:1.5;">Background in process engineering. Has run HAZOP, MOC, and audit cycles before bringing them into SafetyConnect.</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Trust signals -->
<section class="section surface-steel">
  <div class="container">
    <div class="trust-strip__label" style="margin-bottom:24px;text-align:center;">Trusted by global industrial leaders</div>
    <div class="trust-logos" style="margin-bottom:0;">
      <span class="trust-logo">Schindler</span>
      <span class="trust-logo">Cargill</span>
      <span class="trust-logo">Saint-Gobain</span>
      <span class="trust-logo">Mondelez</span>
      <span class="trust-logo">Gilbarco</span>
      <span class="trust-logo">Sun Pharma</span>
    </div>
  </div>
</section>

<!-- FAQ -->
<section class="section surface-white">
  <div class="container">
    <div class="section-header"><span class="eyebrow">FAQ</span><h2 class="display-m">Common questions before booking.</h2></div>
    <div class="faq-list">
      <details class="faq-item" open><summary class="faq-q">Is this a sales pitch?</summary><div class="faq-a">No. It's a 30-minute product walkthrough led by someone who has deployed the platform. We aim to leave you with a clear understanding of fit, not to pressure you into a contract.</div></details>
      <details class="faq-item"><summary class="faq-q">Will you push us through a long sales cycle afterwards?</summary><div class="faq-a">We don't run drip campaigns. After the call, you'll get a follow-up email with the resources we promised. If you're not ready to move forward, that's fine.</div></details>
      <details class="faq-item"><summary class="faq-q">Can I bring my IT or security team?</summary><div class="faq-a">Yes. Multiple stakeholders are encouraged on a single call, or we can split the 30 minutes into a product walkthrough and a separate security walkthrough.</div></details>
      <details class="faq-item"><summary class="faq-q">What if I'm just researching?</summary><div class="faq-a">Pick "Exploring" as your primary interest. We'll tailor the call to your stage, and you'll leave with the resources you need to build an internal business case.</div></details>
    </div>
  </div>
</section>

  <SiteFooter />

</BaseLayout>
