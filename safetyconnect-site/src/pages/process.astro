---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteNav from '../components/SiteNav.astro';
import SiteFooter from '../components/SiteFooter.astro';
import '../styles/global.css';
---

<BaseLayout
  title="Process Safety suite — PTW, incidents, audits, CAPA | SafetyConnect"
  description="Digitise permit-to-work, incident investigation, audits, and CAPA tracking in one connected process safety platform."
>
  <SiteNav />

<!-- Hero -->
<section class="hero surface-white">
  <div class="container">
    <div style="display:grid;grid-template-columns:1.1fr 1fr;gap:64px;align-items:center;">
      <div>
        <span class="eyebrow">Process Safety</span>
        <h1 class="display-l" style="margin-bottom:24px;">Process safety for industrial operations, without the paperwork.</h1>
        <p class="lead">Digital permits, observations, incidents, audits, and action tracking on a single platform. HAZOP, OPA, JSA, MOC and the rest of the practices your process safety team already runs, on one digital workflow that’s tracked to closure. Built for pharma, chemicals, manufacturing, oil and gas, and any operation that cannot afford to get this wrong.</p>
        <div class="hero-actions">
          <a href="/demo" class="btn btn-primary btn-lg">Book a 30-minute walkthrough</a>
          <a href="/pricing" class="btn btn-secondary btn-lg">See pricing</a>
        </div>
      </div>
      <div style="display:flex;gap:24px;align-items:center;justify-content:center;">
        <!-- Mobile permit -->
        <div class="phone">
          <div class="phone__screen">
            <div class="phone__statusbar"><span>9:41</span><span>PLANT 02 · SHIFT B</span></div>
            <div class="phone__appbar">
              <div class="phone__title">Hot Work Permit</div>
              <span class="phone__mode" style="background:rgba(240,80,112,0.12);color:#B53B53;">PENDING</span>
            </div>
            <div style="padding:12px;background:var(--steel-50);border-radius:6px;margin-bottom:12px;">
              <div style="font-size:10px;color:var(--steel-600);letter-spacing:0.06em;">PERMIT NO.</div>
              <div style="font-family:'JetBrains Mono',monospace;font-size:13px;color:var(--navy);font-weight:600;margin-top:2px;">PTW-HW-28471</div>
            </div>
            <div style="font-size:11px;color:var(--steel-600);margin-bottom:6px;">REQUESTOR</div>
            <div style="font-size:13px;font-weight:600;color:var(--navy);margin-bottom:12px;">R. Krishnan · Maintenance</div>
            <div style="font-size:11px;color:var(--steel-600);margin-bottom:6px;">LOCATION</div>
            <div style="font-size:13px;color:var(--navy);margin-bottom:12px;">Unit 4 · Reactor R-201</div>
            <div style="font-size:11px;color:var(--steel-600);margin-bottom:6px;">VALID</div>
            <div style="font-size:13px;color:var(--navy);margin-bottom:16px;">14:00, 18:00 · Today</div>
            <div style="display:flex;gap:6px;margin-bottom:8px;">
              <div style="flex:1;padding:8px;background:rgba(25,167,206,0.10);border:1px solid var(--teal);border-radius:4px;text-align:center;font-size:11px;color:#0E7B97;font-weight:600;">✓ Gas test</div>
              <div style="flex:1;padding:8px;background:rgba(25,167,206,0.10);border:1px solid var(--teal);border-radius:4px;text-align:center;font-size:11px;color:#0E7B97;font-weight:600;">✓ Isolation</div>
            </div>
            <div style="display:flex;gap:6px;margin-bottom:14px;">
              <div style="flex:1;padding:8px;background:var(--steel-50);border:1px solid var(--steel-300);border-radius:4px;text-align:center;font-size:11px;color:var(--steel-600);">Approve</div>
              <div style="flex:1;padding:8px;background:var(--steel-50);border:1px solid var(--steel-300);border-radius:4px;text-align:center;font-size:11px;color:var(--steel-600);">Sign-off</div>
            </div>
            <div style="padding:10px;background:var(--pink);border-radius:6px;text-align:center;font-size:12px;color:#fff;font-weight:600;">Approve permit</div>
          </div>
        </div>
        <!-- Action tracker -->
        <div class="product-ui" style="width:320px;">
          <div class="product-ui__chrome">
            <span class="product-ui__dot"></span><span class="product-ui__dot"></span><span class="product-ui__dot"></span>
            <span class="product-ui__url">ps.safetyconnect.io / actions</span>
          </div>
          <div style="padding:18px;">
            <div style="font-size:11px;color:var(--steel-600);letter-spacing:0.08em;">ACTION TRACKING · OPEN</div>
            <div style="font-size:18px;font-weight:600;color:var(--navy);margin-top:6px;margin-bottom:16px;">24 actions · 6 overdue</div>
            <div style="display:flex;flex-direction:column;gap:8px;">
              <div style="padding:10px;border:1px solid var(--steel-200);border-radius:6px;">
                <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:4px;"><span style="font-size:10px;font-family:'JetBrains Mono',monospace;color:var(--steel-500);">ACT-1847</span><span class="band band--needs" style="font-size:9px;">OVERDUE</span></div>
                <div style="font-size:12px;font-weight:500;color:var(--navy);line-height:1.3;">Replace LOTO devices on Reactor 201</div>
                <div style="font-size:10px;color:var(--steel-500);margin-top:4px;">Due 12 May · Owner: R. Kumar</div>
              </div>
              <div style="padding:10px;border:1px solid var(--steel-200);border-radius:6px;">
                <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:4px;"><span style="font-size:10px;font-family:'JetBrains Mono',monospace;color:var(--steel-500);">ACT-1849</span><span class="band band--medium" style="font-size:9px;">DUE TUE</span></div>
                <div style="font-size:12px;font-weight:500;color:var(--navy);line-height:1.3;">HIRA review for confined-space SOP</div>
                <div style="font-size:10px;color:var(--steel-500);margin-top:4px;">Due 20 May · Owner: P. Mehta</div>
              </div>
              <div style="padding:10px;border:1px solid var(--steel-200);border-radius:6px;">
                <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:4px;"><span style="font-size:10px;font-family:'JetBrains Mono',monospace;color:var(--steel-500);">ACT-1852</span><span class="band band--good" style="font-size:9px;">ON TRACK</span></div>
                <div style="font-size:12px;font-weight:500;color:var(--navy);line-height:1.3;">Refresher: emergency response drill</div>
                <div style="font-size:10px;color:var(--steel-500);margin-top:4px;">Due 28 May · Owner: S. Iyer</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Plant safety problem -->
<section class="section surface-steel">
  <div class="container">
    <div class="section-header section-header--center">
      <span class="eyebrow">Plant safety challenges</span>
      <h2 class="display-m">Six things that make plant safety harder than it should be.</h2>
      <p>Your process safety team already knows the methodologies. What slows them down is how the work moves, across binders, inboxes, and spreadsheets that never quite line up.</p>
    </div>
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:20px;">
<div style="background:#fff;border:1px solid var(--steel-200);border-radius:12px;padding:28px;"><div style="width:48px;height:48px;border-radius:11px;background:rgba(240,80,112,0.10);display:flex;align-items:center;justify-content:center;margin-bottom:16px;"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#F05070" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4a7 7 0 1 0 7 7"/><path d="M11 8v3l2 2"/><path d="M16 4l3 3M19 4l-3 3"/></svg></div><h3 style="font-size:17px;font-weight:600;color:var(--navy);margin-bottom:8px;line-height:1.3;">Improper risk assessment</h3><p style="font-size:14px;color:var(--steel-700);line-height:1.55;">Risks get assessed in spreadsheets that nobody updates, with controls that nobody verifies. The HIRA, JSA, or HAZOP that sits in a folder is not the one the floor is following.</p></div>
<div style="background:#fff;border:1px solid var(--steel-200);border-radius:12px;padding:28px;"><div style="width:48px;height:48px;border-radius:11px;background:rgba(26,39,68,0.09);display:flex;align-items:center;justify-content:center;margin-bottom:16px;"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#1A2744" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="3" width="14" height="18" rx="2"/><path d="M9 8h6M9 12h6M9 16h3"/><circle cx="17" cy="17" r="3" fill="none"/><path d="M17 15v3"/></svg></div><h3 style="font-size:17px;font-weight:600;color:var(--navy);margin-bottom:8px;line-height:1.3;">Inadequate incident reporting</h3><p style="font-size:14px;color:var(--steel-700);line-height:1.55;">Near-misses go unrecorded because reporting is a paper form on a desk somewhere. The serious incident you investigate next quarter started as a near-miss you never saw.</p></div>
<div style="background:#fff;border:1px solid var(--steel-200);border-radius:12px;padding:28px;"><div style="width:48px;height:48px;border-radius:11px;background:rgba(25,167,206,0.12);display:flex;align-items:center;justify-content:center;margin-bottom:16px;"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#19A7CE" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="7" r="3"/><path d="M5 22v-2a4 4 0 0 1 4-4h6a4 4 0 0 1 4 4v2"/><path d="M18 6v2M18 11v.01"/></svg></div><h3 style="font-size:17px;font-weight:600;color:var(--navy);margin-bottom:8px;line-height:1.3;">Human error</h3><p style="font-size:14px;color:var(--steel-700);line-height:1.55;">People skip a step under pressure, miss a checklist item on a long shift, or are not trained on the SOP that landed yesterday. Without a visible workflow, errors compound.</p></div>
<div style="background:#fff;border:1px solid var(--steel-200);border-radius:12px;padding:28px;"><div style="width:48px;height:48px;border-radius:11px;background:rgba(26,39,68,0.09);display:flex;align-items:center;justify-content:center;margin-bottom:16px;"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#1A2744" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M5 9a7 7 0 0 1 14 0"/><circle cx="12" cy="13" r="2"/><path d="M9 21h6"/><path d="M12 17v4"/><path d="M3 9h2M19 9h2"/></svg></div><h3 style="font-size:17px;font-weight:600;color:var(--navy);margin-bottom:8px;line-height:1.3;">Emergency preparedness</h3><p style="font-size:14px;color:var(--steel-700);line-height:1.55;">Drills happen once a year and are not tied to the live risks on the floor. Roles, response times, and contacts live in binders that get out of date.</p></div>
<div style="background:#fff;border:1px solid var(--steel-200);border-radius:12px;padding:28px;"><div style="width:48px;height:48px;border-radius:11px;background:rgba(240,80,112,0.10);display:flex;align-items:center;justify-content:center;margin-bottom:16px;"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#F05070" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M19 9V5a2 2 0 0 0-2-2H7a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h7"/><path d="M9 7h6M9 11h4"/><path d="M16 17l2 2 4-4"/></svg></div><h3 style="font-size:17px;font-weight:600;color:var(--navy);margin-bottom:8px;line-height:1.3;">Compliance</h3><p style="font-size:14px;color:var(--steel-700);line-height:1.55;">Auditors arrive and your team spends a week reconstructing trails from email, signatures, and shift notes. Compliance becomes a manual exercise, not an outcome.</p></div>
<div style="background:#fff;border:1px solid var(--steel-200);border-radius:12px;padding:28px;"><div style="width:48px;height:48px;border-radius:11px;background:rgba(25,167,206,0.12);display:flex;align-items:center;justify-content:center;margin-bottom:16px;"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#19A7CE" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg></div><h3 style="font-size:17px;font-weight:600;color:var(--navy);margin-bottom:8px;line-height:1.3;">Poor communication</h3><p style="font-size:14px;color:var(--steel-700);line-height:1.55;">Permit issuers, area owners, contractors, and managers each have a different view of what was approved, who is doing what, and where the risk sits right now.</p></div>
    </div>
  </div>
</section>

<!-- The Process Safety modules (5) -->
<section class="section surface-white">
  <div class="container">
    <div class="section-header">
      <span class="eyebrow">The modules</span>
      <h2 class="display-m">Five modules. One platform. Audit-ready by design.</h2>
      <p>One unified dashboard for the safety management workflows that run your plant. HAZOP, OPA, JSA, MOC and the rest of the practices sit on top of these five.</p>
    </div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:24px;">
      <div class="card card--lg"><div style="display:flex;align-items:center;gap:14px;margin-bottom:14px;"><div style="width:48px;height:48px;border-radius:11px;background:rgba(240,80,112,0.10);display:flex;align-items:center;justify-content:center;flex-shrink:0;"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#F05070" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="6" y="2" width="12" height="20" rx="2"/><path d="M9 2v2h6V2M9 10h6M9 14h4"/></svg></div><div class="lead-num" style="margin:0;">01</div></div><h3 class="h2 mb-2">E-Permit to Work</h3><p class="text-secondary body mb-3">Hot work, cold work, confined space, working at height, electrical isolation, chemical work, and any custom permit type. Location-based approvals with automated escalations. Multi-level signatures on mobile. Full audit trail.</p><a href="#" class="btn-tertiary arrow-right">Explore Permit to Work</a></div>
      <div class="card card--lg"><div style="display:flex;align-items:center;gap:14px;margin-bottom:14px;"><div style="width:48px;height:48px;border-radius:11px;background:rgba(25,167,206,0.12);display:flex;align-items:center;justify-content:center;flex-shrink:0;"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#19A7CE" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7z"/></svg></div><div class="lead-num" style="margin:0;">02</div></div><h3 class="h2 mb-2">Observation Reporting</h3><p class="text-secondary body mb-3">A mobile channel for anyone on site to report unsafe conditions and unsafe acts. Every observation is logged, categorised, and routed to an owner, so what your team notices on the floor actually gets acted on.</p><a href="#" class="btn-tertiary arrow-right">Explore Observation Reporting</a></div>
      <div class="card card--lg"><div style="display:flex;align-items:center;gap:14px;margin-bottom:14px;"><div style="width:48px;height:48px;border-radius:11px;background:rgba(26,39,68,0.09);display:flex;align-items:center;justify-content:center;flex-shrink:0;"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#1A2744" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 22h20L12 2z"/><path d="M12 9v6M12 18v.01"/></svg></div><div class="lead-num" style="margin:0;">03</div></div><h3 class="h2 mb-2">Incident Reporting</h3><p class="text-secondary body mb-3">Capture incidents and near-misses from the floor in seconds, with photos, location, and witnesses attached automatically. Multi-level investigation workflow with root-cause analysis. From incident to closure on one digital trail.</p><a href="#" class="btn-tertiary arrow-right">Explore Incident Reporting</a></div>
      <div class="card card--lg"><div style="display:flex;align-items:center;gap:14px;margin-bottom:14px;"><div style="width:48px;height:48px;border-radius:11px;background:rgba(25,167,206,0.12);display:flex;align-items:center;justify-content:center;flex-shrink:0;"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#19A7CE" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M9 11l3 3L22 4M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg></div><div class="lead-num" style="margin:0;">04</div></div><h3 class="h2 mb-2">Audit Management</h3><p class="text-secondary body mb-3">Centralise all your audit data on one platform. Standardise audit processes across sites. Build your own checklists or use the public library. Internal, external, and regulatory audits, all in one place.</p><a href="#" class="btn-tertiary arrow-right">Explore Audit Management</a></div>
      <div class="card card--lg" style="grid-column:span 2;"><div style="display:flex;align-items:center;gap:14px;margin-bottom:14px;"><div style="width:48px;height:48px;border-radius:11px;background:rgba(240,80,112,0.10);display:flex;align-items:center;justify-content:center;flex-shrink:0;"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#F05070" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 1 1-9-9"/><path d="M21 3v6h-6"/><path d="M9 12l2 2 4-4"/></svg></div><div class="lead-num" style="margin:0;">05</div></div><h3 class="h2 mb-2">Action Tracking (CAPA)</h3><p class="text-secondary body mb-3">Every action from every audit, observation, and incident, in one tracker. Assign owners, set deadlines, escalate delays, automate alerts, and report on closure rates. The single source of truth your safety committee actually trusts.</p><a href="#" class="btn-tertiary arrow-right">Explore CAPA Tracking</a></div>
    </div>
  </div>
</section>

<!-- Training, managed services, counselling -->
<section class="section surface-steel">
  <div class="container">
    <div class="section-header section-header--center">
      <span class="eyebrow">More than the platform</span>
      <h2 class="display-m">Training, managed services, and counselling, run by us.</h2>
      <p>The platform is the tool. We bring the surrounding services your safety programme needs to actually move, all delivered by our own team, not handed off to a partner network.</p>
    </div>
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:24px;">
      <div style="padding:32px;background:#fff;border:1px solid var(--steel-200);border-radius:12px;">
        <div style="width:48px;height:48px;border-radius:11px;background:rgba(240,80,112,0.10);display:flex;align-items:center;justify-content:center;margin-bottom:18px;">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#F05070" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>
        </div>
        <h3 style="font-size:18px;font-weight:600;color:var(--navy);margin-bottom:10px;">Training</h3>
        <p style="font-size:14.5px;color:var(--steel-700);line-height:1.55;margin-bottom:14px;">PSM fundamentals, HIRA and JSA, incident investigation, audit readiness for ISO 45001 and OSH Code, run for your team by ours.</p>
        <a href="#" class="btn-tertiary arrow-right" style="font-size:13px;">Talk about training</a>
      </div>
      <div style="padding:32px;background:#fff;border:1px solid var(--steel-200);border-radius:12px;">
        <div style="width:48px;height:48px;border-radius:11px;background:rgba(25,167,206,0.12);display:flex;align-items:center;justify-content:center;margin-bottom:18px;">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#19A7CE" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 1 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 1 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 1 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 1 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
        </div>
        <h3 style="font-size:18px;font-weight:600;color:var(--navy);margin-bottom:10px;">Managed services</h3>
        <p style="font-size:14.5px;color:var(--steel-700);line-height:1.55;margin-bottom:14px;">For teams without dedicated analytics or admin bandwidth, we run the platform alongside you, with reporting, programme reviews, and adoption support.</p>
        <a href="#" class="btn-tertiary arrow-right" style="font-size:13px;">Talk about managed services</a>
      </div>
      <div style="padding:32px;background:#fff;border:1px solid var(--steel-200);border-radius:12px;">
        <div style="width:48px;height:48px;border-radius:11px;background:rgba(26,39,68,0.09);display:flex;align-items:center;justify-content:center;margin-bottom:18px;">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#1A2744" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
        </div>
        <h3 style="font-size:18px;font-weight:600;color:var(--navy);margin-bottom:10px;">Counselling</h3>
        <p style="font-size:14.5px;color:var(--steel-700);line-height:1.55;margin-bottom:14px;">Behaviour change is what closes the last mile on safety. We counsel individuals and teams when the data shows someone needs more than a workflow.</p>
        <a href="#" class="btn-tertiary arrow-right" style="font-size:13px;">Talk about counselling</a>
      </div>
    </div>
  </div>
</section>

<!-- Industries -->
<section class="section surface-white">
  <div class="container">
    <div class="section-header section-header--center">
      <span class="eyebrow">Industries</span>
      <h2 class="display-m">Built for industries that cannot afford to get this wrong.</h2>
    </div>
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:20px;">
