<script>
// Page navigation (shared by mockup picker tabs + in-page links)
function goToPage(id) {
  const target = document.getElementById('page-' + id);
  if (!target) return false;
  document.querySelectorAll('.mockup-tab').forEach(t => t.classList.remove('active'));
  const tab = document.querySelector('.mockup-tab[data-tab="' + id + '"]');
  if (tab) tab.classList.add('active');
  document.querySelectorAll('.page-mock').forEach(p => p.classList.remove('active'));
  target.classList.add('active');
  window.scrollTo({top: 0, behavior: 'instant'});
  return true;
}

// Mockup picker tabs
document.querySelectorAll('.mockup-tab').forEach(tab => {
  tab.addEventListener('click', () => goToPage(tab.dataset.tab));
});

// In-page link routing (nav, footer, CTAs, "Explore X" links)
const PAGE_ROUTES = {
  'home':'home','homepage':'home',
  'driving safety':'driving','process safety':'process','forklift safety':'forklift','safety intelligence':'intelligence',
  'permit-to-work':'ptw','permit to work':'ptw',
  'incident management':'incident','incident reporting':'incident','observation reporting':'observations','observations':'observations','observation management':'observations',
  'audit management':'audit','capa tracking':'ats',
  'trust & security':'trust','trust and security':'trust',
  'pricing':'pricing','see pricing':'pricing',
  'book a 30-minute walkthrough':'demo','book a walkthrough':'demo','get a demo':'demo','book a demo':'demo',
  'our story':'about','about':'about','about us':'about',
  'blog':'blog','resources':'blog','products':'driving',
  'read our trust & security commitments':'trust','talk to our team':'demo','talk to us':'demo',
  'all ptw articles':'blog','all incident articles':'blog','all articles':'blog','see all articles':'blog','read the case study':'blog'
};
function routeFromText(t) {
  t = (t || '').toLowerCase().replace(/\s+/g,' ').trim();
  t = t.replace(/^explore\s+/,'').replace(/\s*→\s*$/,'').replace(/[.,]$/,'').trim();
  return PAGE_ROUTES[t];
}
document.addEventListener('click', function(e) {
  const a = e.target.closest('a');
  if (!a) return;
  const href = a.getAttribute('href') || '';
  if (a.classList.contains('site-nav__logo')) {          // logo -> home
    e.preventDefault(); goToPage('home'); return;
  }
  if (href.startsWith('#') && href.length > 1) {          // hash hrefs e.g. #driving, #process
    const id = href.slice(1);
    if (document.getElementById('page-' + id)) { e.preventDefault(); goToPage(id); return; }
  }
  if (href && href !== '#') return;                       // genuine external links behave normally
  const route = routeFromText(a.textContent || '');       // text-based routing for "#" links
  e.preventDefault();                                     // suppress the "#" jump in all cases
  if (route) goToPage(route);
});

// Hero variant toggle (homepage only)
document.querySelectorAll('.hero-toggle').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.hero-toggle').forEach(b => {
      b.classList.remove('active');
      b.style.background = 'transparent';
      b.style.borderColor = 'rgba(240,80,112,0.4)';
    });
    btn.classList.add('active');
    btn.style.background = '#fff';
    btn.style.borderColor = '#F05070';
    const variant = btn.dataset.hero;
    document.getElementById('hero-white').style.display = (variant === 'white') ? 'block' : 'none';
    document.getElementById('hero-navy').style.display  = (variant === 'navy')  ? 'block' : 'none';
  });
});

// ROI calculator (pricing page) - per product
function initROI(){
  const fmtINR = n => {
    n = Math.max(0, Math.round(n));
    if (n >= 10000000){ let v=(n/10000000); return '\u20b9' + (v % 1 === 0 ? v.toFixed(0) : v.toFixed(1)) + ' Cr'; }
    if (n >= 100000) return '\u20b9' + Math.round(n/100000).toLocaleString('en-IN') + 'L';
    return '\u20b9' + n.toLocaleString('en-IN');
  };
  const num = id => { const el = document.getElementById(id); return el ? (parseFloat(el.value)||0) : 0; };
  const set = (id,v) => { const el = document.getElementById(id); if (el) el.textContent = v; };
  const cnt = n => (n < 10 ? n.toFixed(1) : Math.round(n).toLocaleString('en-IN'));

  function calcDriving(){
    const inc = num('rd-incidents'), cost = num('rd-cost');
    const avoided = inc * 0.60, save = avoided * cost;
    set('rd-out-avoided', cnt(avoided)); set('rd-out-cost', fmtINR(save)); set('rd-out-total', fmtINR(save));
  }
  function calcProcess(){
    const inc = num('rp-incidents'), cost = num('rp-cost'), pen = num('rp-penalty');
    const avoided = inc * 0.55, incSave = avoided * cost, penSave = pen * 0.70;
    set('rp-out-avoided', cnt(avoided)); set('rp-out-cost', fmtINR(incSave));
    set('rp-out-penalty', fmtINR(penSave)); set('rp-out-total', fmtINR(incSave + penSave));
  }
  function calcForklift(){
    const fk = num('rf-forklifts'), nm = num('rf-nearmiss'), cost = num('rf-cost');
    const nmAvoided = nm * 0.50, util = fk * cost * 0.20;
    set('rf-out-nm', cnt(nmAvoided)); set('rf-out-util', fmtINR(util)); set('rf-out-total', fmtINR(util));
  }
  const recalc = { driving: calcDriving, process: calcProcess, forklift: calcForklift };
  if (!document.getElementById('rd-drivers')) return;
  Object.keys(recalc).forEach(k=>{
    const panel = document.getElementById('roi-panel-'+k);
    if (panel) panel.querySelectorAll('input').forEach(i=> i.addEventListener('input', recalc[k]));
  });
  document.querySelectorAll('.roi-tab').forEach(btn=>{
    btn.addEventListener('click', ()=>{
      const t = btn.getAttribute('data-roi');
      document.querySelectorAll('.roi-tab').forEach(b=> b.classList.toggle('roi-tab--active', b===btn));
      ['driving','process','forklift'].forEach(k=>{
        const p = document.getElementById('roi-panel-'+k);
        if (p) p.style.display = (k===t) ? 'grid' : 'none';
      });
      recalc[t]();
    });
  });
  calcDriving(); calcProcess(); calcForklift();
}
document.addEventListener('DOMContentLoaded', initROI);
</script>

