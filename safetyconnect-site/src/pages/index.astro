---
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>SafetyConnect — Software that prevents workplace incidents</title>
  <meta name="description" content="SafetyConnect helps enterprises prevent workplace incidents with connected driving, process, and forklift safety." />
  <meta property="og:title" content="SafetyConnect — Software that prevents workplace incidents" />
  <meta property="og:type" content="website" />
  <meta name="robots" content="index,follow" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Mona+Sans:ital,wght@0,400;0,500;0,600;0,700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <script type="application/ld+json">
{"@context":"https://schema.org","@type":"Organization","name":"SafetyConnect","url":"https://www.safetyconnect.io","logo":"https://www.safetyconnect.io/logo.png","description":"Connected workplace safety software — driving, process, and forklift safety.","contactPoint":{"@type":"ContactPoint","contactType":"sales","areaServed":["IN","US"]}}
</script>
<script type="application/ld+json">
{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Can we keep our existing permit forms?","acceptedAnswer":{"@type":"Answer","text":"Yes. We replicate your existing permit forms in the platform — same fields, same approval chain, same conditions — then progressively digitise the friction points your teams complain about."}},{"@type":"Question","name":"Does it work offline?","acceptedAnswer":{"@type":"Answer","text":"Yes. The mobile app captures permits offline and syncs when connectivity returns."}}]}
</script>
</head>
<body>

<div class="mockup-bar">
  <span class="mockup-bar__label">MOCKUP v0</span>
  <div class="mockup-bar__tabs">
    <button class="mockup-tab active" data-tab="home">Homepage</button>
    <button class="mockup-tab" data-tab="driving">Driving Safety</button>
    <button class="mockup-tab" data-tab="process">Process Safety</button>
    <button class="mockup-tab" data-tab="forklift">Forklift Safety</button>
    <button class="mockup-tab" data-tab="intelligence">Safety Intelligence</button>
    <button class="mockup-tab" onclick="window.location.href='/intelligence-framework'">Safety Intelligence Framework</button>
    <button class="mockup-tab" data-tab="trust">Trust &amp; Security</button>
    <button class="mockup-tab" data-tab="pricing">Pricing</button>
    <button class="mockup-tab" data-tab="demo">Get a Demo</button>
    <button class="mockup-tab" data-tab="about">About</button>
    <button class="mockup-tab" data-tab="blog">Blog</button>
    <span class="mockup-bar__divider">PS modules:</span>
    <button class="mockup-tab mockup-tab--sub" data-tab="ptw">Permit to Work</button>
    <button class="mockup-tab mockup-tab--sub" data-tab="incident">Incident Mgmt</button>
    <button class="mockup-tab mockup-tab--sub" data-tab="observations">Observations</button>
    <button class="mockup-tab mockup-tab--sub" data-tab="audit">Audit Mgmt</button>
    <button class="mockup-tab mockup-tab--sub" data-tab="ats">CAPA Tracking</button>
  </div>
</div>

<nav class="site-nav">
  <div class="site-nav__inner">
    <a href="#" class="site-nav__logo">
      <img src="data:image/png;base64," alt="SafetyConnect" />
    </a>
    <ul class="site-nav__menu">
      <li><a href="#" class="has-dropdown">Products</a></li>
      <li><a href="#">Customers</a></li>
      <li><a href="#">Pricing</a></li>
      <li><a href="#">Trust &amp; Security</a></li>
      <li><a href="#" class="has-dropdown">Resources</a></li>
    </ul>
    <div class="site-nav__actions">
      <a href="https://app.safetyconnect.io/" target="_blank" rel="noopener" class="site-nav__login">Sign in</a>
      <a href="#" class="btn btn-primary">Book a walkthrough</a>
    </div>
  </div>
</nav>

<div class="page-mock active" id="page-home" data-title="SafetyConnect — Software that prevents workplace incidents" data-meta="Prevent driving, process, and forklift incidents with connected safety software: real-time risk detection, investigation, and coaching.">

<!-- HERO -->
<section class="hero hero--white" id="hero-white">
  <div class="container">
    <div style="display:grid;grid-template-columns:1.05fr 1fr;gap:64px;align-items:center;">
      <div>
        <span class="eyebrow">The safety operating system for industrial enterprises</span>
        <h1 class="display-l" style="margin-bottom:24px;letter-spacing:-0.02em;">Two safety risks keep EHS Heads up at night: your field force on the road, and your teams in the plant.</h1>
        <p class="lead">SafetyConnect is the only platform that covers both. Built in India, trusted by safety leaders across the world.</p>
        <div class="hero-actions">
          <a href="#" class="btn btn-primary btn-lg">Book a 30-minute walkthrough</a>
          <a href="#" class="btn btn-secondary btn-lg">See pricing</a>
        </div>
      </div>

      <!-- Composite intelligence panel (no browser chrome) -->
      <div style="background:#fff;border:1px solid var(--steel-200);border-radius:14px;box-shadow:var(--shadow-lg);overflow:hidden;">
        <div style="background:var(--navy);color:#fff;padding:16px 20px;display:flex;justify-content:space-between;align-items:center;">
          <div style="display:flex;align-items:center;gap:10px;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#19A7CE" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M12 2v3m0 14v3M2 12h3m14 0h3M5.6 5.6l2.1 2.1m8.6 8.6l2.1 2.1M5.6 18.4l2.1-2.1m8.6-8.6l2.1-2.1"/></svg>
            <span style="font-size:14px;font-weight:600;letter-spacing:0.01em;">SafetyConnect Intelligence</span>
          </div>
          <span style="display:flex;align-items:center;gap:6px;font-size:11px;color:rgba(255,255,255,0.7);"><span style="width:7px;height:7px;border-radius:50%;background:#19A7CE;box-shadow:0 0 0 3px rgba(25,167,206,0.25);"></span>Live</span>
        </div>

        <div style="padding:18px 20px;">
          <!-- Driving signal -->
          <div style="font-size:10px;color:var(--steel-600);letter-spacing:0.08em;margin-bottom:8px;">DRIVING SAFETY · FIELD FORCE</div>
          <div style="display:flex;flex-direction:column;gap:6px;margin-bottom:18px;">
            <div style="display:flex;justify-content:space-between;align-items:center;padding:9px 12px;background:var(--steel-50);border-radius:6px;">
              <div><div style="font-size:13px;font-weight:600;color:var(--navy);">Michael R.</div><div style="font-size:10px;color:var(--steel-600);">Field Service · West Zone</div></div>
              <div style="display:flex;align-items:center;gap:10px;"><span class="band band--good">Good</span><span style="font-size:20px;font-weight:700;color:var(--navy);">88</span></div>
            </div>
            <div style="display:flex;justify-content:space-between;align-items:center;padding:9px 12px;background:var(--steel-50);border-radius:6px;">
              <div><div style="font-size:13px;font-weight:600;color:var(--navy);">Anand K.</div><div style="font-size:10px;color:var(--steel-600);">Field Sales · North Zone</div></div>
              <div style="display:flex;align-items:center;gap:10px;"><span class="band band--needs">Needs work</span><span style="font-size:20px;font-weight:700;color:var(--navy);">41</span></div>
            </div>
          </div>

          <!-- Process signal -->
          <div style="font-size:10px;color:var(--steel-600);letter-spacing:0.08em;margin-bottom:8px;">PROCESS SAFETY · PLANT FLOOR</div>
          <div style="display:flex;flex-direction:column;gap:6px;margin-bottom:18px;">
            <div style="display:flex;justify-content:space-between;align-items:center;padding:9px 12px;background:var(--steel-50);border-radius:6px;">
              <div><div style="font-size:13px;font-weight:600;color:var(--navy);">Hot Work Permit · Plant 3</div><div style="font-size:10px;color:var(--steel-600);">Zone B-04 · Tank farm</div></div>
              <span style="font-size:11px;background:rgba(240,80,112,0.1);color:var(--pink);padding:4px 9px;border-radius:3px;font-weight:600;">Awaiting sign-off</span>
            </div>
          </div>

          <!-- AI insight callout -->
          <div style="border:1px solid rgba(25,167,206,0.3);background:rgba(25,167,206,0.06);border-radius:8px;padding:14px;">
            <div style="display:flex;align-items:center;gap:8px;margin-bottom:6px;">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#19A7CE" stroke-width="2"><path d="M9 18h6M10 22h4M12 2a7 7 0 0 0-4 12.7V17h8v-2.3A7 7 0 0 0 12 2z"/></svg>
              <span style="font-size:10px;color:var(--teal);letter-spacing:0.08em;font-weight:700;">INTELLIGENCE · PREDICTED RISK</span>
            </div>
            <div style="font-size:13px;color:var(--navy);line-height:1.45;">Loading Bay 4 flagged. Three forklift near-misses this week, up from zero. Recommend a hotspot inspection and operator review.</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Trusted-by logo wall (within hero) -->
    <div style="margin-top:56px;padding-top:32px;border-top:1px solid var(--steel-200);">
      <div style="text-align:center;font-size:12px;color:var(--steel-600);letter-spacing:0.14em;text-transform:uppercase;margin-bottom:28px;">Trusted by global industrial leaders</div>
      <div style="display:grid;grid-template-columns:repeat(5,1fr);gap:10px 24px;align-items:center;">
        <div class="logo-cell"><span class="logo-cell--text">Schindler</span></div>
        <div class="logo-cell"><img src="data:image/png;base64," alt="Cargill" /></div>
        <div class="logo-cell"><img src="data:image/png;base64," alt="Saint-Gobain" /></div>
        <div class="logo-cell"><img src="data:image/png;base64," alt="Mondelez" /></div>
        <div class="logo-cell"><span class="logo-cell--text">Gilbarco<br>Veeder-Root</span></div>
        <div class="logo-cell"><img src="data:image/png;base64," alt="Sun Pharma" /></div>
        <div class="logo-cell"><span class="logo-cell--text">NCR Atleos</span></div>
        <div class="logo-cell"><img src="data:image/png;base64," alt="Carlsberg" /></div>
        <div class="logo-cell"><img src="data:image/png;base64," alt="Tata Motors" /></div>
        <div class="logo-cell"><img src="data:image/png;base64," alt="Syngenta" /></div>
      </div>
    </div>
  </div>
</section>

<!-- STATS band -->
<section class="section surface-white" style="padding-top:72px;padding-bottom:72px;">
  <div class="container">
    <div class="section-header section-header--center" style="margin-bottom:48px;">
      <span class="eyebrow">The outcomes</span>
      <h2 class="display-m">Numbers our customers see.</h2>
      <p>Across the road and the plant floor, on one platform.</p>
    </div>
    <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:0;border:1px solid var(--steel-200);border-radius:14px;overflow:hidden;">
      <div style="padding:44px 26px;text-align:center;border-right:1px solid var(--steel-200);position:relative;">
        <div style="position:absolute;top:0;left:0;right:0;height:4px;background:var(--pink);"></div>
        <div style="font-size:11px;color:var(--steel-500);letter-spacing:0.08em;margin-bottom:14px;">DRIVING SAFETY</div>
        <div style="font-size:56px;font-weight:600;color:var(--navy);line-height:1;letter-spacing:-0.03em;">80<span style="font-size:34px;color:var(--pink);">%</span></div>
        <div style="font-size:14.5px;color:var(--navy);font-weight:600;margin-top:14px;">Fewer road accidents</div>
      </div>
      <div style="padding:44px 26px;text-align:center;border-right:1px solid var(--steel-200);position:relative;">
        <div style="position:absolute;top:0;left:0;right:0;height:4px;background:var(--teal);"></div>
        <div style="font-size:11px;color:var(--steel-500);letter-spacing:0.08em;margin-bottom:14px;">PROCESS SAFETY</div>
        <div style="font-size:56px;font-weight:600;color:var(--navy);line-height:1;letter-spacing:-0.03em;">100<span style="font-size:34px;color:var(--teal);">%</span></div>
        <div style="font-size:14.5px;color:var(--navy);font-weight:600;margin-top:14px;">Of actions tracked to closure</div>
      </div>
      <div style="padding:44px 26px;text-align:center;border-right:1px solid var(--steel-200);position:relative;">
        <div style="position:absolute;top:0;left:0;right:0;height:4px;background:var(--navy);"></div>
        <div style="font-size:11px;color:var(--steel-500);letter-spacing:0.08em;margin-bottom:14px;">FIELD PRODUCTIVITY</div>
        <div style="font-size:56px;font-weight:600;color:var(--navy);line-height:1;letter-spacing:-0.03em;">30<span style="font-size:34px;color:var(--navy);">%</span></div>
        <div style="font-size:14.5px;color:var(--navy);font-weight:600;margin-top:14px;">Gain in field force productivity</div>
      </div>
      <div style="padding:44px 26px;text-align:center;position:relative;">
        <div style="position:absolute;top:0;left:0;right:0;height:4px;background:var(--steel-500);"></div>
        <div style="font-size:11px;color:var(--steel-500);letter-spacing:0.08em;margin-bottom:14px;">RETURN</div>
        <div style="font-size:56px;font-weight:600;color:var(--navy);line-height:1;letter-spacing:-0.03em;">&lt;3<span style="font-size:24px;color:var(--steel-600);font-weight:600;"> mo</span></div>
        <div style="font-size:14.5px;color:var(--navy);font-weight:600;margin-top:14px;">Typical time to ROI</div>
      </div>
    </div>
    <div style="text-align:center;font-size:11px;color:var(--pink);margin-top:16px;font-style:italic;">Content note: confirm a verified process-safety reduction metric (e.g. recordable incident rate) to strengthen this further.</div>
  </div>
</section>

<!-- TWO RISKS, ONE PLATFORM -->
<section class="section surface-steel">
  <div class="container">
    <div class="section-header section-header--center">
      <span class="eyebrow">The problem we solve</span>
      <h2 class="display-m">Two risks. One platform.</h2>
      <p>Most safety software handles one environment. Your people move between two. SafetyConnect is built for both.</p>
    </div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:32px;">

      <!-- On the road -->
      <div style="background:#fff;border:1px solid var(--steel-200);border-radius:16px;padding:0;position:relative;overflow:hidden;display:flex;flex-direction:column;">
        <div style="height:5px;background:linear-gradient(90deg,var(--teal),rgba(25,167,206,0.4));"></div>
        <div style="padding:44px;flex:1;display:flex;flex-direction:column;">
          <div style="display:flex;align-items:center;gap:16px;margin-bottom:24px;">
            <div style="width:60px;height:60px;border-radius:14px;background:rgba(25,167,206,0.1);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
              <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="#19A7CE" stroke-width="1.6"><path d="M5 17H3v-5l2-5h11l3 5h2v5h-2"/><circle cx="7.5" cy="17.5" r="2.5"/><circle cx="17.5" cy="17.5" r="2.5"/><path d="M5 12h14"/></svg>
            </div>
            <div>
              <div style="font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--steel-500);letter-spacing:0.08em;">RISK ONE</div>
              <h3 class="h1" style="margin:2px 0 0;">On the road</h3>
            </div>
          </div>
          <p style="font-size:16px;color:var(--steel-700);line-height:1.55;margin-bottom:28px;">Your field force drives more than anyone in the company. Service engineers, sales teams, and technicians log thousands of kilometres a month. Road incidents are the leading cause of workplace fatalities in most field organisations, and the hardest to see coming.</p>
          <div style="font-size:11px;color:var(--steel-500);letter-spacing:0.08em;margin-top:auto;margin-bottom:12px;">WHAT WE WATCH FOR</div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
            <div class="risk-chip"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#19A7CE" stroke-width="1.8"><rect x="7" y="2" width="10" height="20" rx="2"/><path d="M11 18h2"/></svg>Distraction</div>
            <div class="risk-chip"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#19A7CE" stroke-width="1.8"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7z"/><path d="M5 5l14 14"/></svg>Fatigue</div>
            <div class="risk-chip"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#19A7CE" stroke-width="1.8"><path d="M12 14l4-4M4 18a8 8 0 1 1 16 0"/></svg>Overspeeding</div>
            <div class="risk-chip"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#19A7CE" stroke-width="1.8"><path d="M12 2L2 22h20L12 2z"/><path d="M12 10v5M12 18h.01"/></svg>Harsh driving</div>
          </div>
        </div>
      </div>

      <!-- In the plant -->
      <div style="background:#fff;border:1px solid var(--steel-200);border-radius:16px;padding:0;position:relative;overflow:hidden;display:flex;flex-direction:column;">
        <div style="height:5px;background:linear-gradient(90deg,var(--pink),rgba(240,80,112,0.4));"></div>
        <div style="padding:44px;flex:1;display:flex;flex-direction:column;">
          <div style="display:flex;align-items:center;gap:16px;margin-bottom:24px;">
            <div style="width:60px;height:60px;border-radius:14px;background:rgba(240,80,112,0.1);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
              <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="#F05070" stroke-width="1.6"><path d="M2 20h20M4 20V9l5 3V9l5 3V8l6 3v9"/><path d="M9 20v-4h3v4"/></svg>
            </div>
            <div>
              <div style="font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--steel-500);letter-spacing:0.08em;">RISK TWO</div>
              <h3 class="h1" style="margin:2px 0 0;">In the plant</h3>
            </div>
          </div>
          <p style="font-size:16px;color:var(--steel-700);line-height:1.55;margin-bottom:28px;">Your plant floor runs on permits, procedures, and the discipline of a thousand small checks. Paper permits, missed inspections, untracked hazards, and forklift blind spots are where incidents begin, and where audit trails fall apart.</p>
          <div style="font-size:11px;color:var(--steel-500);letter-spacing:0.08em;margin-top:auto;margin-bottom:12px;">WHERE IT GOES WRONG</div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
            <div class="risk-chip risk-chip--pink"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#F05070" stroke-width="1.8"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/></svg>Permits</div>
            <div class="risk-chip risk-chip--pink"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#F05070" stroke-width="1.8"><circle cx="12" cy="12" r="3"/><path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7z"/></svg>Observations</div>
            <div class="risk-chip risk-chip--pink"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#F05070" stroke-width="1.8"><circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/></svg>Incidents</div>
            <div class="risk-chip risk-chip--pink"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#F05070" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 12H5a2 2 0 0 0-2 2v5"/><circle cx="13" cy="19" r="2"/><circle cx="5" cy="19" r="2"/><path d="M8 19h3m5-17v17h6"/><path d="M6 12V7c0-1.1.9-2 2-2h3l5 5"/></svg>Forklifts</div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- HOW IT WORKS (sneak peek) -->
<section class="section surface-navy">
  <div class="container">
    <div class="section-header section-header--center">
      <span class="eyebrow">A look inside</span>
      <h2 class="display-m" style="color:#fff;">How we solve both.</h2>
      <p style="color:rgba(255,255,255,0.72);">A quick look at how the platform works on the road and on the plant floor. For the full picture, explore each product.</p>
    </div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:28px;">

      <!-- Driving preview -->
      <div style="background:#fff;border-radius:14px;padding:36px;display:flex;flex-direction:column;">
        <div style="font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--teal);letter-spacing:0.08em;margin-bottom:10px;">ON THE ROAD</div>
        <h3 class="h2" style="margin-bottom:10px;">From the phone in their pocket</h3>
        <p style="font-size:15px;color:var(--steel-700);line-height:1.55;margin-bottom:24px;">The app reads motion sensors to detect distraction, fatigue, overspeeding, and harsh driving, then turns each trip into a SafetyConnect Score the driver and their manager can act on. No hardware, no camera.</p>
