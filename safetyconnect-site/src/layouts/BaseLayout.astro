---
export interface Props {
  title?: string;
  description?: string;
}

const {
  title = "SafetyConnect — Software that prevents workplace incidents",
  description = "SafetyConnect helps enterprises prevent workplace incidents with connected driving, process, and forklift safety — real-time risk detection, structured investigation, and coaching that builds safer habits."
} = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta property="og:title" content={title} />
  <meta property="og:type" content="website" />
  <meta name="robots" content="index,follow" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Mona+Sans:ital,wght@0,400;0,500;0,600;0,700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <script type="application/ld+json">
    {"@context":"https://schema.org","@type":"Organization","name":"SafetyConnect","url":"https://www.safetyconnect.io","logo":"https://www.safetyconnect.io/logo.png","description":"Connected workplace safety software — driving, process, and forklift safety.","contactPoint":{"@type":"ContactPoint","contactType":"sales","areaServed":["IN","US"]}}
  </script>
</head>
<body>
  <slot />
</body>
</html>
